<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV Digital - M. Idham Baihaqi</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        body { background: #0f172a; color: #f1f5f9; font-family: sans-serif; margin: 0; display: flex; }
        .sidebar { width: 300px; background: #1e293b; padding: 40px 20px; display: flex; flex-direction: column; align-items: center; border-right: 3px solid #38bdf8; position: fixed; height: 100%; box-sizing: border-box; }
        .profile-img { width: 200px; height: 200px; border-radius: 20px; border: 4px solid #38bdf8; object-fit: cover; margin-bottom: 20px; box-shadow: 0 10px 20px rgba(0,0,0,0.5); }
        .sidebar h2 { font-size: 20px; text-align: center; color: #38bdf8; margin: 10px 0; }
        .content { margin-left: 300px; padding: 50px; flex-grow: 1; width: calc(100% - 300px); box-sizing: border-box; }
        .section { background: #1e293b; padding: 30px; border-radius: 15px; margin-bottom: 30px; border: 1px solid #334155; }
        h1 { color: #38bdf8; border-left: 5px solid #38bdf8; padding-left: 15px; margin-bottom: 20px; }
        .item { margin-bottom: 20px; border-left: 2px solid #334155; padding-left: 15px; }
        .item b { font-size: 18px; color: #f1f5f9; display: block; }
        .item small { color: #38bdf8; font-weight: bold; }
    </style>
</head>
<body>
    <div class="sidebar">
        <img src="foto-idham.jpg" class="profile-img" alt="M. Idham Baihaqi">
        <h2>M. IDHAM BAIHAQI</h2>
        <p style="color: #94a3b8; text-align: center;">Audio Video Specialist</p>
        <a href="https://instagram.com/damnzzz9" style="color: #38bdf8; font-size: 30px; margin-top: 20px;"><i class="fa-brands fa-instagram"></i></a>
    </div>
    <div class="content">
        <div class="section">
            <h1>Pendidikan</h1>
            <div class="item"><b>SMK NU 03 KALIWUNGU</b><small>Teknik Audio Video | 2021 - 2024</small></div>
            <div class="item"><b>SMP Muhammadiyah 03 Kaliwungu</b><small>2018 - 2021</small></div>
            <div class="item"><b>MI Muhammadiyah Sarirejo</b><small>2012 - 2018</small></div>
        </div>
        <div class="section">
            <h1>Pengalaman</h1>
            <div class="item"><b>Asisten Operasional</b><small>Desember 2024 - Sekarang</small></div>
            <div class="item"><b>Operator Produksi</b><small>PT Prym Intimates | 2024</small></div>
        </div>
    </div>
</body>
</html>

